PORT=4000
NODE_ENV=production
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/f1f   # remove when Postgres retired
JWT_SECRET=replace_me_with_long_random_value
JWT_EXPIRES_IN=1h
FRONTEND_URL=http://localhost:3000
# Optional: separate frontend URLs for debug and production
FRONTEND_URL_DEBUG=http://localhost:3000
FRONTEND_URL_PROD=https://teal-ganache-11922e.netlify.app
# Optional: comma-separated override list for allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002,https://teal-ganache-11922e.netlify.app
# Optional: explicit backend URLs
BACKEND_URL_DEBUG=http://localhost:4000
BACKEND_URL_PROD=https://f1-fantasy-league-backend.onrender.com
DEBUG=false
BOOTSTRAP_ADMIN_KEY=local-bootstrap-key
PICK_LOCK_MINUTES_BEFORE_DEADLINE=30
JOLPICA_AUTO_SYNC_ENABLED=true
JOLPICA_AUTO_SYNC_INTERVAL_MS=900000
JOLPICA_AUTO_SYNC_SEASON=2026
# MongoDB Atlas connection string for production
MONGODB_URI=
# Or provide credentials (the app will construct the Atlas URI automatically)
MONGO_USERNAME=
MONGO_PASSWORD=
# Local/dev Mongo URI
MONGO_URI_DEV=mongodb://localhost:27017/f1f
# Optional seed overrides for scripts/reset-season-2026.js
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_KEY=local-bootstrap-key
PICK_LOCK_MINUTES_BEFORE_DEADLINE=30
