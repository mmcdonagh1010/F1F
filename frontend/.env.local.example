# API base used in development/debug builds
NEXT_PUBLIC_API_BASE_DEBUG=http://localhost:4000/api
# API base used in production builds (set this when deploying)
NEXT_PUBLIC_API_BASE_PROD=https://f1-fantasy-league-backend.onrender.com/api
# Fallback or generic API base if you don't use separate vars
NEXT_PUBLIC_API_BASE=http://localhost:4000/api
# Set to "true" to force using the DEBUG API base in non-production
NEXT_PUBLIC_DEBUG=false
